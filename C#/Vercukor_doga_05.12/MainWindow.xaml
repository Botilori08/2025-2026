<Window x:Class="Vercukor_doga_05._12.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vercukor_doga_05._12"
        mc:Ignorable="d"
        Title="Vércukor napló" Height="450" Width="800">
    <Grid>
        <Label Content="Nap száma:" HorizontalAlignment="Left" Margin="32,40,0,0" VerticalAlignment="Top" FontSize="16"/>
        <TextBox x:Name="Napszam" HorizontalAlignment="Left" Margin="203,45,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="137" Height="22"/>
        <Label Content="Napszak:" HorizontalAlignment="Left" Margin="32,82,0,0" VerticalAlignment="Top" FontSize="16"/>
        <ComboBox x:Name="Napszak" HorizontalAlignment="Left" Margin="203,87,0,0" VerticalAlignment="Top" Width="137">
            <ComboBoxItem Content="reggel"/>
            <ComboBoxItem Content="délben"/>
            <ComboBoxItem Content="este"/>
        </ComboBox>
        <Label Content="Mért érték:" HorizontalAlignment="Left" Margin="32,167,0,0" VerticalAlignment="Top" FontSize="16"/>
        <TextBox x:Name="Ertek" HorizontalAlignment="Left" Margin="203,172,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="137" Height="22"/>
        <Label x:Name="valasz" Content="" HorizontalAlignment="Left" Margin="360,170,0,0" VerticalAlignment="Top"/>
        <Label Content="Étkezés előtt v. után?" HorizontalAlignment="Left" Margin="32,128,0,0" VerticalAlignment="Top" FontSize="16" Width="161"/>
        <ComboBox x:Name="Meresmod" HorizontalAlignment="Left" Margin="203,133,0,0" VerticalAlignment="Top" Width="137">
            <ComboBoxItem Content="Éhgyomorra"/>
            <ComboBoxItem Content="Étkezés után 2 órával"/>
        </ComboBox>
        <Label x:Name="valaszNapszam" Content="" HorizontalAlignment="Left" Margin="355,43,0,0" VerticalAlignment="Top"/>
        <Button Content="Rögzít" HorizontalAlignment="Left" Margin="32,245,0,0" VerticalAlignment="Top" Width="308" Height="26" Click="Button_Click"/>
        <DataGrid d:ItemsSource="{d:SampleData ItemCount=1}" Margin="370,0,0,0"/>

    </Grid>
</Window>
