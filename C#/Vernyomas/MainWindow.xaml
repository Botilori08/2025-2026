<Window x:Class="Vernyomas.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vernyomas"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Margin="0,0,10,0">
        <DataGrid x:Name="Megjelenit"  HorizontalAlignment="Left" Width="390" Margin="400,0,0,0">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nap sorszáma"></DataGridTextColumn>
                <DataGridTextColumn Header="Napszak"></DataGridTextColumn>
                <DataGridTextColumn Header="Szisztolés"></DataGridTextColumn>
                <DataGridTextColumn Header="Disztolés"></DataGridTextColumn>

                <DataGridTextColumn Header="Pulzus"></DataGridTextColumn>
            </DataGrid.Columns>
        </DataGrid>
        <TextBox x:Name="napSzam" HorizontalAlignment="Left" Margin="102,58,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="71"/>
        <Label Content="Vérnyomás" HorizontalAlignment="Left" Margin="10,10,0,0" VerticalAlignment="Top" Width="152" FontSize="18"/>
        <Label Content="Nap sorszáma:" HorizontalAlignment="Left" Margin="10,54,0,0" VerticalAlignment="Top"/>
        <Label Content="Napszak:" HorizontalAlignment="Left" Margin="10,94,0,0" VerticalAlignment="Top"/>
        <ComboBox x:Name="napszakValaszt" HorizontalAlignment="Left" Margin="102,98,0,0" VerticalAlignment="Top" Width="71" Height="22"/>
        <TextBox x:Name="szisztoles" HorizontalAlignment="Left" Margin="102,134,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="71"/>
        <Label Content="Szisztolés:" HorizontalAlignment="Left" Margin="10,130,0,0" VerticalAlignment="Top"/>
        <Label Content="Disztolés:" HorizontalAlignment="Left" Margin="10,161,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="disztolés" HorizontalAlignment="Left" Margin="102,165,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="71"/>
        <Label Content="Pulzusszám:" HorizontalAlignment="Left" Margin="10,192,0,0" VerticalAlignment="Top"/>
        <TextBox x:Name="pulzus" HorizontalAlignment="Left" Margin="102,196,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="71"/>
        <Button Content="Rögzítés" HorizontalAlignment="Left" Margin="108,250,0,0" VerticalAlignment="Top" Width="152" Height="29" Click="Button_Click"/>
        <Button Content="Fájlbaírás" HorizontalAlignment="Left" Margin="108,308,0,0" VerticalAlignment="Top" Width="152" Height="30"/>
        <Label x:Name="valasz" Content="" HorizontalAlignment="Left" Margin="179,244,0,0" VerticalAlignment="Top"/>
        <Label x:Name="napValasz" Content="" HorizontalAlignment="Left" Margin="184,54,0,0" VerticalAlignment="Top"/>
        <Label x:Name="szisztolesValasz" Content="" HorizontalAlignment="Left" Margin="184,130,0,0" VerticalAlignment="Top"/>
        <Label x:Name="disztolesValasz" Content="" HorizontalAlignment="Left" Margin="184,161,0,0" VerticalAlignment="Top"/>
        <Label x:Name="pulzusValasz" Content="" HorizontalAlignment="Left" Margin="184,192,0,0" VerticalAlignment="Top"/>
    </Grid>

</Window>
