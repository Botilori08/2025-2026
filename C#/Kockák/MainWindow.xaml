<Window x:Class="Kockák.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Kockák"
        mc:Ignorable="d"
        Title="MainWindow" Height="624" Width="800">
    <Grid>
        <Image HorizontalAlignment="Left" Height="100" Margin="94,80,0,0" VerticalAlignment="Top" Width="100" Source="/Anni.png"/>
        <Image HorizontalAlignment="Left" Height="100" Margin="606,80,0,0" VerticalAlignment="Top" Width="100" Source="/Panni.png"/>
