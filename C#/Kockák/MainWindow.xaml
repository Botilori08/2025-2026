        <Label Content="Panni" HorizontalAlignment="Left" Margin="632,34,0,0" VerticalAlignment="Top" FontSize="16"/>
        <TextBox x:Name="dobasokSzama" HorizontalAlignment="Center" Margin="0,91,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="90" Height="39" FontSize="24"/>
        <Label Content="Dobások száma" HorizontalAlignment="Center" Margin="0,33,0,0" VerticalAlignment="Top" FontSize="18"/>
        <Button Content="Játék indítása" HorizontalAlignment="Center" Margin="0,163,0,0" VerticalAlignment="Top" Width="90" Height="25" Click="Button_Click"/>
        <StackPanel x:Name="asztal" Margin="0,225,0,0"/>
        <Label x:Name="valasz" Content="" HorizontalAlignment="Center" Margin="0,135,0,0" VerticalAlignment="Top"/>
        <Label x:Name="anniWinek" Content="" HorizontalAlignment="Left" Margin="139,189,0,0" VerticalAlignment="Top" FontSize="16"/>
        <Label x:Name="panniWinek" Content="" HorizontalAlignment="Left" Margin="651,189,0,0" VerticalAlignment="Top" FontSize="16"/>

    </Grid>
</Window>
