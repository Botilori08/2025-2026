<Window x:Class="kraterek.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:kraterek"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <TabControl>
            <TabItem Header="2. feladat">
                <Grid Background="#FFE5E5E5">
                    <TextBlock x:Name="kraterSzam" HorizontalAlignment="Left" Margin="41,179,0,0" TextWrapping="Wrap" VerticalAlignment="Top" Width="591" FontSize="22"/>
                    <Label Content="Kráterek száma " HorizontalAlignment="Left" Margin="41,23,0,0" VerticalAlignment="Top" FontSize="36" Grid.ColumnSpan="2"/>
                    <Button x:Name="gomb1" Content="Keresés" HorizontalAlignment="Left" Margin="41,111,0,0" VerticalAlignment="Top" Width="122" Height="39" FontSize="16" Click="Button_Click"/>
                </Grid>
            </TabItem>
            <TabItem Header="3. feladat">
                <Grid Background="#FFE5E5E5">
                    <TextBox x:Name="Bekertnev" HorizontalAlignment="Left" Margin="211,83,0,0" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Width="191" Height="32" FontSize="20"/>
                    <Label Content="Add meg egy kráter nevét!" HorizontalAlignment="Left" Margin="46,86,0,0" VerticalAlignment="Top"/>
                    <Label Content="3. feladat" HorizontalAlignment="Left" Margin="41,25,0,0" VerticalAlignment="Top" FontSize="24"/>
                    <Button x:Name="kereses" Content="Lekérdez" HorizontalAlignment="Left" Margin="46,142,0,0" VerticalAlignment="Top" Width="356" Height="26" Click="kereses_Click"/>
                    <Label x:Name="adatKiir" Content="" HorizontalAlignment="Center" Margin="0,203,0,0" VerticalAlignment="Top" Width="702" Height="47"/>
                </Grid>
            </TabItem>
            <TabItem Header="4. feladat">
                <Grid Background="#FFE5E5E5" Loaded="Grid_Loaded">
                    <Label Content="4. feladat" HorizontalAlignment="Left" Margin="51,33,0,0" VerticalAlignment="Top" FontSize="24"/>
                    <Label Content="A legnagyobb sugarú kráter adatai" HorizontalAlignment="Left" Margin="51,80,0,0" VerticalAlignment="Top" Width="404" FontSize="24"/>
                    <Label Content="Label" HorizontalAlignment="Center" Margin="0,146,0,0" VerticalAlignment="Top" Width="698" Height="209"/>
                </Grid>
            </TabItem>
            <TabItem Header="5. feladat">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="TabItem">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="TabItem">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="TabItem">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
        </TabControl>

    </Grid>
</Window>
